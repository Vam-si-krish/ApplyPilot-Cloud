# ApplyPilot résumé worker — copy to .env and fill in.

# Port the worker listens on (Cloudflare Tunnel points a subdomain here).
PORT=8787

# Shared secret. The Netlify app sends `Authorization: Bearer <WORKER_SECRET>`.
# Must match RESUME_WORKER_SECRET in the Netlify env. Use a long random string.
WORKER_SECRET=

# Supabase (service role — server-only, never ships to a browser).
SUPABASE_URL=https://ftrakpebzcabztwyunum.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket for generated PDFs (created by migration 0019).
RESUMES_BUCKET=resumes

# ── Claude subscription mode (ADR 0042) ──────────────────────────────────────
# Lets AI tasks run on your Claude Pro/Max plan via the Agent SDK instead of a paid
# API key (selected per task in the app: Settings → AI Models → "Claude subscription").
# One-time setup on THIS machine:
#   1) npm i -g @anthropic-ai/claude-code   (the CLI the SDK drives)
#   2) claude setup-token                   (prints a 1-year OAuth token)
# Paste the token below. Alternatively run `claude login` once and leave this blank.
CLAUDE_CODE_OAUTH_TOKEN=
# IMPORTANT: do NOT set ANTHROPIC_API_KEY / ANTHROPIC_AUTH_TOKEN in this worker's
# environment — they take precedence over the subscription and would bill the API.
# (The worker still uses Anthropic *vault* keys for API-mode tasks; those are passed
#  to the API directly, not via these env vars.)
# Optional: explicit path to the `claude` binary if auto-resolution fails.
# CLAUDE_CLI_PATH=
