# ApplyPilot résumé worker — copy to .env and fill in.

# Port the worker listens on (Cloudflare Tunnel points a subdomain here).
PORT=8787

# Shared secret. The Netlify app sends `Authorization: Bearer <WORKER_SECRET>`.
# Must match RESUME_WORKER_SECRET in the Netlify env. Use a long random string.
WORKER_SECRET=

# Supabase (service role — server-only, never ships to a browser).
SUPABASE_URL=https://ftrakpebzcabztwyunum.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket for generated PDFs (created by migration 0019).
RESUMES_BUCKET=resumes
