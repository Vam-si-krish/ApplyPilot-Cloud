# ─── ApplyPilot-Cloud environment ───────────────────────────────────────────
# Copy to .env.local for local dev. In production set these in the Vercel
# project's Environment Variables. NEVER commit real secrets.

# ── Supabase (Postgres + storage) ────────────────────────────────────────────
# Project URL and keys from the Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key bypasses RLS — server-side ONLY, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Auth (single shared password) ────────────────────────────────────────────
# The one password that gates the whole app (ADR 0003).
APP_PASSWORD=change-me-to-a-long-random-string
# Secret used to sign the session cookie. Generate: openssl rand -hex 32
AUTH_SECRET=generate-with-openssl-rand-hex-32

# ── Apify (job fetching) ─────────────────────────────────────────────────────
# Token from https://console.apify.com/account/integrations.
# Optional FALLBACK: the active Apify key in Settings → API Keys takes precedence
# (ADR 0006). Keep set so runs work before any key is added in the UI.
APIFY_TOKEN=apify_api_xxx
# Default actor (overridable per-user in Settings). LinkedIn jobs scraper.
APIFY_ACTOR_ID=bebity~linkedin-jobs-scraper

# ── Cron auth ────────────────────────────────────────────────────────────────
# Vercel Cron sends this as a Bearer token to /api/run. Generate a random value.
CRON_SECRET=generate-with-openssl-rand-hex-32

# ── LLM provider (scoring) ───────────────────────────────────────────────────
# Optional FALLBACK: provider keys are normally managed in Settings → API Keys,
# where the active key per provider takes precedence (ADR 0006). These env vars
# are used only when a provider has no stored key. Set ONE; provider is
# auto-detected (Gemini preferred), same as ApplyPilot-Lite.
GEMINI_API_KEY=your-gemini-key
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
# Optional overrides:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the deployment (used to build the Apify webhook URL).
NEXT_PUBLIC_APP_URL=http://localhost:3000
